# Server (host port mapped to the app container)
PORT=5000

# Redis — runs in Docker on the same VPS as the API.
# Set a strong password; used by the redis container and REDIS_URL below.
# Do NOT expose port 6379 on the VPS firewall.
REDIS_PASSWORD=change-this-to-a-long-random-string

# Database (MongoDB Atlas or other external host)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/chatapp

# Auth
JWT_SECRET=your-jwt-secret
JWT_EXPIRES=7d

# Cloudinary (optional, for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---
# VPS setup (one time on the server):
#   1. Install Docker: https://docs.docker.com/engine/install/ubuntu/
#   2. Clone repo, copy this file to .env and fill values
#   3. docker compose up -d --build
#   4. Open only PORT (e.g. 5000) in the security group / UFW — not 6379
#
# If you previously used Redis Cloud, remove REDIS_URL from .env —
# docker-compose sets REDIS_URL to the local Redis container automatically.
# dvcywgtr873y
